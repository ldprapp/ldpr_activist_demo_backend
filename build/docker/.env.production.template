# --- Production environment template ---
# Copy this file to:
#   build/docker/.env.production
# and replace placeholder values.

# --- Infrastructure ---
POSTGRES_DB=ldpr_activist
POSTGRES_USER=ldpr_activist
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# Connection strings used by API container
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=ldpr_activist;Username=ldpr_activist;Password=CHANGE_ME_STRONG_POSTGRES_PASSWORD;Include Error Detail=false
REDIS_CONNECTION_STRING=redis:6379

# External HTTP port exposed by nginx
API_PORT=80
HTTPS_PORT=443

# Public base URL used by release health/version verification.
# Must point to the real externally reachable production entrypoint.
PUBLIC_BASE_URL=https://aktivist.pro

# --- Runtime environment ---
DOTNET_ENVIRONMENT=Production
SWAGGER_ENABLED=false

DATABASE_AUTO_MIGRATE=false

# --- Rate limiting ---
RATE_LIMITING_ENABLED=true
RATE_LIMITING_PUBLIC_AUTHENTICATION_PERMIT_LIMIT=5
RATE_LIMITING_PUBLIC_AUTHENTICATION_WINDOW_SECONDS=60
RATE_LIMITING_PUBLIC_AUTHENTICATION_QUEUE_LIMIT=0
RATE_LIMITING_PUBLIC_OTP_CONFIRMATION_PERMIT_LIMIT=10
RATE_LIMITING_PUBLIC_OTP_CONFIRMATION_WINDOW_SECONDS=60
RATE_LIMITING_PUBLIC_OTP_CONFIRMATION_QUEUE_LIMIT=0
RATE_LIMITING_AUTHENTICATED_MUTATION_PERMIT_LIMIT=30
RATE_LIMITING_AUTHENTICATED_MUTATION_WINDOW_SECONDS=60
RATE_LIMITING_AUTHENTICATED_MUTATION_QUEUE_LIMIT=0

# --- PostgreSQL backups ---
DB_BACKUP_ROOT_PATH_CONTAINER=/var/backups/postgres
DB_BACKUP_ROOT_PATH_HOST=/var/backups/ldpr_activist/postgres
DB_BACKUP_INTERVAL_SECONDS=86400
DB_BACKUP_RETENTION_DAYS=14
DB_BACKUP_FILE_PREFIX=ldpr_activist
BACKUP_ENVIRONMENT_NAME=production
POSTGRES_BACKUP_SCRIPT_PATH=/scripts/postgres-backup.prod.sh
POSTGRES_BACKUP_LOOP_SCRIPT_PATH=/scripts/postgres-backup-loop.prod.sh

# --- Structured logging ---
STRUCTURED_LOGGING_SERVICE_NAME=ldpr-activist-demo.api
STRUCTURED_LOGGING_SERVICE_NAMESPACE=LdprActivistDemo
STRUCTURED_LOGGING_INSTANCE_ID=
STRUCTURED_LOGGING_MIN_LEVEL_DEFAULT=Information
STRUCTURED_LOGGING_MIN_LEVEL_MICROSOFT=Warning
STRUCTURED_LOGGING_MIN_LEVEL_MICROSOFT_ASPNETCORE=Warning
STRUCTURED_LOGGING_MIN_LEVEL_MICROSOFT_ENTITYFRAMEWORKCORE=Warning
STRUCTURED_LOGGING_MIN_LEVEL_SYSTEM=Warning
STRUCTURED_LOGGING_CONSOLE_ENABLED=true
STRUCTURED_LOGGING_FILES_ENABLED=true
STRUCTURED_LOGGING_FILES_ROOT_PATH_CONTAINER=/var/log/ldpr-activist-demo/api
STRUCTURED_LOGGING_FILES_ROOT_PATH_HOST=/var/log/ldpr_activist/api
STRUCTURED_LOGGING_FILES_SHARED=true
STRUCTURED_LOGGING_FILES_FILE_SIZE_LIMIT_BYTES=52428800
STRUCTURED_LOGGING_FILES_ROLL_ON_FILE_SIZE_LIMIT=true
STRUCTURED_LOGGING_FILES_RETAINED_FILE_COUNT_LIMIT=30
STRUCTURED_LOGGING_FILES_DATE_SINK_MAP_COUNT_LIMIT=14
STRUCTURED_LOGGING_FILES_LEVEL_SINK_MAP_COUNT_LIMIT=8

# --- OTP config ---
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# --- SMS.ru ---
SMS_RU_API_ID=PUT_YOUR_PRODUCTION_SMS_RU_API_ID_HERE
SMS_RU_IS_TEST_MODE=false
SMS_RU_BASE_URL=https://sms.ru

# --- Application time ---
APPLICATION_TIME_LOCALE=ru-RU

# --- Firebase push ---
FIREBASE_PUSH_ENABLED=true
FIREBASE_PUSH_BASE_URL=https://fcm.googleapis.com
FIREBASE_PUSH_PROJECT_ID=ldpr-activist
FIREBASE_PUSH_SERVICE_ACCOUNT_JSON_PATH=/run/secrets/firebase/service-account.json

# --- Build / image ---
DOTNET_VERSION=10.0
APP_PROJECT=src/LdprActivistDemo.Api/LdprActivistDemo.Api.csproj
APP_DLL=LdprActivistDemo.Api.dll
API_IMAGE_NAME=ldpr-activist-demo-api
API_IMAGE_TAG=production-latest