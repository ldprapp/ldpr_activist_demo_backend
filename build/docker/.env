# --- Infrastructure (demo credentials) ---
POSTGRES_DB=ldpr_activist_demo
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo

# Host/ports: docker-network vs host-machine
POSTGRES_HOST_DOCKER=postgres
POSTGRES_HOST_HOST=localhost
POSTGRES_PORT_PUBLIC=5432

REDIS_HOST_DOCKER=redis
REDIS_HOST_HOST=localhost
REDIS_PORT_PUBLIC=6379

# Connection strings (demo: дублирование ок для удобства)
POSTGRES_CONNECTION_STRING_DOCKER=Host=postgres;Port=5432;Database=ldpr_activist_demo;Username=demo;Password=demo;Include Error Detail=true
POSTGRES_CONNECTION_STRING_HOST=Host=localhost;Port=5432;Database=ldpr_activist_demo;Username=demo;Password=demo;Include Error Detail=true

REDIS_CONNECTION_STRING_DOCKER=redis:6379
REDIS_CONNECTION_STRING_HOST=localhost:6379

API_PORT=8080

DATABASE_AUTO_MIGRATE=true

# --- OTP config ---
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# --- .NET / build ---
DOTNET_VERSION=10.0

# Путь к .csproj API (от корня репозитория)
APP_PROJECT=src/LdprActivistDemo.Api/LdprActivistDemo.Api.csproj

# Имя dll (обычно совпадает с именем csproj)
APP_DLL=LdprActivistDemo.Api.dll
